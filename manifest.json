{
  "manifest_version": 3,
  "name": "QA Tool Kit",
  "version": "2.0",
  "description": "One-click QA page scanning for broken links, images, and performance issues.",
  "author": "Ruturaj Sharbidre",
  "permissions": [
    "activeTab",
    "tabs",
    "history",
    "scripting",
    "storage",
    "alarms",
    "downloads",
    "notifications",
    "desktopCapture",
    "offscreen",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "take_screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capture Screenshot"
    }
  },
  "background": {
    "scripts": [
      "scripts/browser_polyfill.js",
      "scripts/background.js"
    ],
    "service_worker": "scripts/background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "qa-toolkit@ruturajsh.com",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scripts/browser_polyfill.js",
        "scripts/keyword_spotter.js",
        "scripts/note_tagger.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/recorder_helper.html",
        "scripts/browser_polyfill.js",
        "scripts/recorder.js",
        "scripts/screenshot.js",
        "scripts/scanner.js",
        "scripts/measure.js",
        "scripts/url_extractor.js",
        "scripts/recorder_inline.js",
        "scripts/content_overlay.js",
        "scripts/keyword_spotter.js",
        "scripts/note_tagger.js",
        "scripts/form_filler.js",
        "scripts/console_collector.js",
        "scripts/whole_screen_screenshot.js",
        "scripts/full_page_screenshot.js",
        "scripts/visible_screenshot.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}